# Example local environment configuration for dihiggs_boundary
# Save this file as `.env.local` at the root of the repository

# Root directory of the repository
DIHIGGS_REPO_ROOT=/home/user/code/dihiggs_boundary

# Data lake configurations
DIHIGGS_CERN_DB_ROOT=/home/user/cern_db
DIHIGGS_LAKE_NAME=dihiggs_lake
DIHIGGS_LAKE_ROOT=/home/user/cern_db/dihiggs_lake

# Output paths for runs
DIHIGGS_RUN_ROOT=/home/user/runs/dihiggs_boundary

# Paths to dependencies
DIHIGGS_2HDMC_ROOT=/home/user/code/dihiggs_boundary/lib/2HDMC-1.8.0
DIHIGGS_HIGGSTOOLS_ROOT=/home/user/code/dihiggs_boundary/lib/higgstools-v1.2

# OpenMP settings
OMP_NUM_THREADS=4
