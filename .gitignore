# Build outputs
build/
cmake-build-*/
*.o
*.so
*.a
*.dll
*.dylib
*.exe

# Runtime data
data/runs/*
!data/runs/.gitkeep
scratch/*
!scratch/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
.env

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/
*.stderr
*.stdout

# Temporary shard files
*.tmp
*.partial

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Large generated data
*.parquet
*.duckdb
*.h5
*.hdf5
*.csv
*.jsonl

# Keep small fixtures if needed
!tests/fixtures/*.csv
!tests/fixtures/*.json
!tests/fixtures/*.jsonl